# scripts/.env.example
# ---------------------------------------------------------------------------
# Copy to scripts/.env and edit. scripts/.env is gitignored.
# common.sh auto-loads scripts/.env at runtime; values exported in your
# shell BEFORE running deploy.sh / bootstrap.sh take precedence.
# ---------------------------------------------------------------------------

# ===== Required =====
export SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
export RESOURCE_GROUP=rg-azure-iot-demo

# ===== Common (have sane defaults; override as needed) =====
export LOCATION=eastus
export BASE_NAME=aiotdemo
export ARC_CLUSTER_NAME=my-edge-cluster

# ===== Edge VM (Ubuntu 24.04 + K3s) =====
export VM_ADMIN_USERNAME=azureuser
# Path to the OpenSSH public key file used to authorize the admin user.
# Generate one with:  ssh-keygen -t ed25519 -f ~/.ssh/id_edge -C edge-demo
export VM_SSH_PUBLIC_KEY_FILE=$HOME/.ssh/id_rsa.pub
export VM_SIZE=Standard_D4s_v5
export VM_OS_DISK_SIZE_GB=64
# Restrict to your IP in non-demo environments, e.g. 203.0.113.10/32
export VM_SSH_SOURCE_CIDR=*
# Networking — override if these ranges collide with a peered VNet.
# VM_SUBNET_CIDR MUST be inside VM_VNET_CIDR.
export VM_VNET_CIDR=10.20.0.0/16
export VM_SUBNET_CIDR=10.20.0.0/24

# ===== Optional SKU/capacity overrides =====
# export IOT_HUB_SKU=S1
# export IOT_HUB_CAPACITY=1
# export ACR_SKU=Standard

# ===== Tags applied to every resource =====
# export TAGS_KV="project=azure-iot-demo env=dev managedBy=azcli"

# ===== Flux / GitOps (only needed for scripts/bootstrap.sh) =====
# export CLUSTER_NAME=my-edge-cluster         # bootstrap.sh; mirrors into ARC_CLUSTER_NAME
# export GITHUB_OWNER=your-github-user-or-org
# export GITHUB_REPO=azure-iot
# DO NOT commit a real token. Prefer: export GITHUB_TOKEN=$(gh auth token)
# export GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===== Skip flags (bootstrap.sh / deploy.sh) =====
# export SKIP_DEPLOY=1
# export SKIP_VM=1
# export SKIP_AIO=1
